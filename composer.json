{
    "name": "mantra/cms",
    "description": "Lightweight flat-file PHP CMS",
    "type": "project",
    "license": "MIT",
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^10.5"
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.1.0"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix"
    }
}
