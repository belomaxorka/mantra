# Mantra CMS — Caddy configuration
#
# Usage:
#   1. Adjust the site address (first line inside the block)
#   2. Adjust root path and php_fastcgi address
#   3. Run: caddy run --config /path/to/Caddyfile
#
# Caddy automatically provisions HTTPS when using a domain name.
# Use ":80" or "localhost" for local development without HTTPS.
#
# PHP-FPM must be running. Adjust php_fastcgi address:
#   - Socket: unix//run/php/php-fpm.sock
#   - TCP:    127.0.0.1:9000

example.com {
	root * /var/www/example.com

	# --- Security: blocked directories ---

	# Hidden files and directories (.git, .env, .htaccess, etc.)
	@hidden path_regexp /\.
	respond @hidden 404

	# Data, logs, and internal code
	@content path /content/*
	respond @content 404

	@storage path /storage/*
	respond @storage 404

	@core path /core/*
	respond @core 404

	# Module internals — block everything except assets
	@moduleInternal {
		path /modules/*
		not path_regexp ^/modules/[^/]+/assets/
		not path_regexp ^/modules/admin/panels/[^/]+/assets/
	}
	respond @moduleInternal 404

	# Theme internals — block templates and config
	@themeInternal path_regexp ^/themes/.*\.(php|json)$
	respond @themeInternal 404

	# --- Security: blocked file types ---

	@sensitive path_regexp \.(json|md|lock|bak|sql|tmp|dist|log)$
	respond @sensitive 404

	# Block PHP in uploads
	@uploadPhp path_regexp ^/uploads/.*\.php
	respond @uploadPhp 404

	# --- PHP & static files ---

	php_fastcgi unix//run/php/php-fpm.sock
	# php_fastcgi 127.0.0.1:9000
	file_server
	encode gzip
}
