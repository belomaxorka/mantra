AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
    RewriteEngine on
    RewriteBase /

    # Deny direct access to sensitive directories
    RewriteRule ^content/(users|settings)/.*$ - [R=404,L]
    RewriteRule ^storage/logs/.*$ - [R=404,L]

    # Allow access to core assets (CSS, JS, images)
    RewriteCond %{REQUEST_URI} !^/core/assets/
    RewriteRule ^core/.*$ - [R=404,L]

    RewriteRule ^modules/.*/lang/.*$ - [R=404,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*) index.php [PT,L]
</IfModule>
