AddDefaultCharset UTF-8

<IfModule mod_rewrite.c>
    RewriteEngine on
    RewriteBase /

    # Block hidden files and directories (.git, .env, etc.)
    RewriteRule (^\.|/\.) - [R=404,L]

    # Block sensitive directories entirely
    RewriteRule ^content/ - [R=404,L]
    RewriteRule ^storage/ - [R=404,L]
    RewriteRule ^core/ - [R=404,L]

    # Block module internals — allow only assets subdirectories
    RewriteCond %{REQUEST_URI} !^/modules/[^/]+/assets/
    RewriteCond %{REQUEST_URI} !^/modules/admin/panels/[^/]+/assets/
    RewriteRule ^modules/ - [R=404,L]

    # Block theme templates and config
    RewriteRule ^themes/.*\.(php|json)$ - [R=404,L]

    # Block sensitive file extensions
    RewriteRule \.(json|md|lock|bak|sql|tmp|dist|log)$ - [R=404,L]

    # Block PHP execution in uploads
    RewriteRule ^uploads/.*\.php$ - [R=404,L]

    # Block docker configuration
    RewriteRule ^docker/ - [R=404,L]

    # Allow only index.php and install.php as entry points
    RewriteCond %{THE_REQUEST} \.php
    RewriteRule !^(index|install)\.php$ - [R=404,L]

    # Front controller
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*) index.php [PT,L]
</IfModule>
